@model WaybillApp.Models.FuelNorm
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Редактировать норму" : "Новая норма расхода";
}

<div class="card" style="max-width:560px">
  <form method="post" asp-action="@(isEdit ? "Edit" : "Create")">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="Id"/> }

    <div class="form-grid">
      <div class="form-group" style="grid-column:1/-1">
        <label>Название нормы</label>
        <input asp-for="Name" placeholder="Например: Норма 2025"/>
      </div>
      <div class="form-group">
        <label>Базовая норма (л/100 км)</label>
        <input asp-for="BaseNorm" type="number" step="0.01" oninput="recalc()"/>
      </div>
      <div class="form-group">
        <label>Коэффициент на груз (дробь)</label>
        <input asp-for="KCargo" type="number" step="0.01" placeholder="0.05" oninput="recalc()"/>
        <small style="color:#6b6b66">0.05 = +5%</small>
      </div>
      <div class="form-group">
        <label>Коэффициент на город (дробь)</label>
        <input asp-for="KCity" type="number" step="0.01" placeholder="0.10" oninput="recalc()"/>
        <small style="color:#6b6b66">0.10 = +10%</small>
      </div>
      <div class="form-group">
        <label>Коэффициент на зиму (дробь)</label>
        <input asp-for="KWinter" type="number" step="0.01" placeholder="0.20" oninput="recalc()"/>
        <small style="color:#6b6b66">0.20 = +20%</small>
      </div>
      <div class="form-group">
        <label>Действует с</label>
        <input asp-for="EffectiveFrom" type="date"/>
      </div>
      <div class="form-group" style="grid-column:1/-1">
        <label>Примечание</label>
        <input asp-for="Notes" placeholder="Например: по приказу №123"/>
      </div>
    </div>

    <!-- Live preview -->
    <div style="margin-top:16px;padding:12px 16px;background:#f8fafc;border:1px solid var(--border);border-radius:8px">
      <div style="font-size:12px;font-weight:600;color:#6b6b66;margin-bottom:8px">Предпросмотр норм</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 16px;font-size:13px" id="preview"></div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">@(isEdit ? "Сохранить" : "Создать")</button>
      <a class="btn btn-secondary" asp-action="Index">Отмена</a>
    </div>
  </form>
</div>

@section Scripts {
<script>
function recalc() {
  const base   = parseFloat(document.querySelector('[name=BaseNorm]').value)  || 0;
  const cargo  = parseFloat(document.querySelector('[name=KCargo]').value)    || 0;
  const city   = parseFloat(document.querySelector('[name=KCity]').value)     || 0;
  const winter = parseFloat(document.querySelector('[name=KWinter]').value)   || 0;

  const norms = [
    ['Загород, лето, без груза', base],
    ['Загород, лето, с грузом',  base * (1+cargo)],
    ['Загород, зима, без груза', base * (1+winter)],
    ['Загород, зима, с грузом',  base * (1+cargo) * (1+winter)],
    ['Город, лето, без груза',   base * (1+city)],
    ['Город, лето, с грузом',    base * (1+cargo) * (1+city)],
    ['Город, зима, без груза',   base * (1+winter) * (1+city)],
    ['Город, зима, с грузом',    base * (1+cargo) * (1+winter) * (1+city)],
  ];

  document.getElementById('preview').innerHTML = norms.map(([label, val]) =>
    `<div style="color:#6b6b66">${label}</div><div><strong>${val.toFixed(2)}</strong> л/100 км</div>`
  ).join('');
}
recalc();
</script>
}
