@{
    Layout = null;
    ViewData["Title"] = "Вход";
}
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8"/>
<title>Вход — Путевые листы</title>
<link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="3"/>
        <path d="M8 7h8M8 11h8M8 15h5"/>
      </svg>
      <h1 style="margin:0">Путевые листы</h1>
    </div>
    <p style="color:#6b6b66;font-size:13px;margin-bottom:24px">Введите данные для входа</p>

    @if (!ViewData.ModelState.IsValid)
    {
      <div class="alert alert-error">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        { <div>@err.ErrorMessage</div> }
      </div>
    }

    <form method="post" action="/Account/Login">
      @Html.AntiForgeryToken()
      <div class="form-group" style="margin-bottom:14px">
        <label>Логин</label>
        <input name="username" type="text" required autofocus placeholder="admin"/>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Пароль</label>
        <input name="password" type="password" required placeholder="••••••"/>
      </div>
      <div class="form-check" style="margin-bottom:20px">
        <input name="remember" type="checkbox" id="rem"/>
        <label for="rem" style="font-size:13px;color:#6b6b66">Запомнить меня</label>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">Войти</button>
    </form>
  </div>
</div>
</body>
</html>
