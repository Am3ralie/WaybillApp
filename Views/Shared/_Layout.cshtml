<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>@ViewData["Title"] — Путевые листы</title>
<link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
<div class="layout">
  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="3"/>
        <path d="M8 7h8M8 11h8M8 15h5"/>
      </svg>
      <span>Путевые листы</span>
    </div>
    <div class="sidebar-user">
      <div class="user-dot"></div>
      <div>
        <div class="user-name">@User.Identity.Name</div>
        <div class="user-role">
          @if (User.IsInRole("admin")) { <span>Администратор</span> }
          else if (User.IsInRole("operator")) { <span>Оператор</span> }
          else { <span>Водитель</span> }
        </div>
      </div>
    </div>
    <ul class="nav-links">
      <li><a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        Главная
      </a></li>
      <li><a asp-controller="Waybills" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Waybills"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>
        Путевые листы
      </a></li>
      <li><a asp-controller="Drivers" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Drivers"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Водители
      </a></li>
      <li><a asp-controller="Vehicles" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Vehicles"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15l3 8H1V3z"/><circle cx="5.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
        Транспорт
      </a></li>
      <li><a asp-controller="FuelNorms" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="FuelNorms"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 16l4-4 4 4 4-8"/></svg>
        Нормы топлива
      </a></li>
      @if (User.IsInRole("admin"))
      {
      <li><a asp-controller="Account" asp-action="Users" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Account"?"active":"")">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><circle cx="12" cy="8" r="4"/><path d="M16 20H8a4 4 0 010-8h8a4 4 0 010 8z"/></svg>
        Пользователи
      </a></li>
      }
    </ul>
    <div class="sidebar-bottom">
      <form asp-controller="Account" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="logout-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Выйти
        </button>
      </form>
    </div>
  </nav>

  <!-- Main content -->
  <main class="main-content">
    <div class="page-header">
      <h1>@ViewData["Title"]</h1>
    </div>
    @if (TempData["Success"] != null)
    { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-error">@TempData["Error"]</div> }
    @RenderBody()
  </main>
</div>
}
else
{
  @RenderBody()
}

<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
