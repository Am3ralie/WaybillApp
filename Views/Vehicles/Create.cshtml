@model WaybillApp.Models.Vehicle
@{ bool isEdit = Model.Id > 0; ViewData["Title"] = isEdit ? "Редактировать ТС" : "Новое ТС"; }
<div class="card" style="max-width:560px">
  <form method="post" asp-action="@(isEdit ? "Edit" : "Create")">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="Id"/> }
    <div class="form-grid">
      <div class="form-group"><label>Гос. номер</label><input asp-for="PlateNumber" required placeholder="А000АА 99"/></div>
      <div class="form-group"><label>Марка/Модель</label><input asp-for="Model" placeholder="КАМАЗ-5320"/></div>
      <div class="form-group"><label>VIN</label><input asp-for="Vin"/></div>
      <div class="form-group"><label>Техосмотр до</label><input asp-for="TechInspectionExpiry" type="date"/></div>
      <div class="form-check" style="grid-column:1/-1"><input asp-for="IsActive" type="checkbox" id="va"/><label for="va">Активен</label></div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">@(isEdit ? "Сохранить" : "Создать")</button>
      <a class="btn btn-secondary" asp-action="Index">Отмена</a>
    </div>
  </form>
</div>
